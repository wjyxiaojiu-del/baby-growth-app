/* 全局样式 — 毛玻璃风格 */
page {
  background: linear-gradient(180deg, #FFF0F2 0%, #F8F0FF 30%, #F0F4FF 60%, #FFF5F5 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 主题色 */
.text-primary { color: #FF6B81; }
.text-secondary { color: #FFB5C2; }
.text-dark { color: #333; }
.text-gray { color: #999; }
.text-light { color: #CCC; }

/* ===== 毛玻璃卡片 ===== */
.card {
  background: rgba(255, 255, 255, 0.65);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  border-radius: 28rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow:
    0 8rpx 32rpx rgba(255, 107, 129, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

/* 强调卡片 — 粉色毛玻璃 */
.card-accent {
  background: rgba(255, 240, 242, 0.7);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  border-radius: 28rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 213, 219, 0.5);
  box-shadow:
    0 8rpx 32rpx rgba(255, 107, 129, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

/* 深色毛玻璃卡片 */
.card-dark {
  background: rgba(255, 107, 129, 0.85);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  border-radius: 28rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  color: #FFF;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.25);
}

/* ===== 按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E9E 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.35);
  position: relative;
  overflow: hidden;
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.2) 0%, transparent 100%);
  border-radius: 48rpx 48rpx 0 0;
  pointer-events: none;
}

.btn-secondary {
  background: rgba(255, 240, 242, 0.7);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
  color: #FF6B81;
  border: 1rpx solid rgba(255, 213, 219, 0.6);
  border-radius: 48rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  text-align: center;
  width: 100%;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: rgba(245, 230, 232, 0.6);
  margin: 24rpx 0;
}

/* ===== 表单输入 ===== */
.form-input {
  background: rgba(255, 255, 255, 0.6);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(240, 224, 226, 0.5);
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: rgba(255, 107, 129, 0.5);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 129, 0.08);
}

.form-picker {
  background: rgba(255, 255, 255, 0.6);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(240, 224, 226, 0.5);
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.form-textarea {
  background: rgba(255, 255, 255, 0.6);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(240, 224, 226, 0.5);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  width: 100%;
}

/* ===== 标签/Chip ===== */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
}

.chip.active {
  background: rgba(255, 107, 129, 0.15);
  border-color: rgba(255, 107, 129, 0.4);
  color: #FF6B81;
}

/* ===== 安全底部 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 滚动条隐藏 ===== */
::-webkit-scrollbar { display: none; }
