<view class="page-container">
  <view class="section-title-bar">隐私设置</view>

  <view class="settings-list card">
    <view
      wx:for="{{settings}}"
      wx:key="key"
      class="setting-item"
    >
      <view class="setting-text">
        <text class="setting-label">{{item.label}}</text>
        <text class="setting-desc">{{item.desc}}</text>
      </view>
      <switch
        checked="{{item.value}}"
        color="#FF6B81"
        bindchange="onToggle"
        data-key="{{item.key}}"
      />
    </view>
  </view>

  <view class="section-title-bar">数据管理</view>

  <view class="danger-card card">
    <view class="danger-item" bindtap="deleteAllData">
      <view class="danger-text">
        <text class="danger-label">删除所有数据</text>
        <text class="danger-desc">永久删除所有宝宝记录、报告和设置</text>
      </view>
      <text class="danger-arrow">›</text>
    </view>
  </view>

  <view class="privacy-note">
    <text class="note-title">隐私承诺</text>
    <text class="note-text">• 我们不会收集您的位置信息</text>
    <text class="note-text">• 所有数据仅存储在您的手机本地</text>
    <text class="note-text">• 未经您同意，数据不会分享给第三方</text>
    <text class="note-text">• 您可随时删除所有数据</text>
  </view>
</view>
