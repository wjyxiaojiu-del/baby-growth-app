.page-container { padding-bottom: 60rpx; }

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 48rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFB5C2, #FF6B81);
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.3);
}

.app-name { font-size: 36rpx; font-weight: 700; color: #333; }
.app-version { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.app-slogan { font-size: 26rpx; color: #FF6B81; margin-top: 12rpx; }

.card-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }

.feature-list { display: flex; flex-direction: column; gap: 24rpx; }
.feature-item { display: flex; align-items: center; gap: 20rpx; }

.feature-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(255, 240, 242, 0.6);
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.feature-icon.ai-icon {
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: #FFF;
  font-size: 24rpx;
  font-weight: 700;
  border-color: transparent;
}

.feature-text { flex: 1; }
.feature-title { display: block; font-size: 28rpx; font-weight: 600; color: #333; }
.feature-desc { display: block; font-size: 24rpx; color: #999; margin-top: 4rpx; }

.info-card { display: flex; flex-direction: column; gap: 24rpx; }
.info-item { display: flex; flex-direction: column; gap: 8rpx; }
.info-label { font-size: 26rpx; font-weight: 600; color: #333; }
.info-value { font-size: 26rpx; color: #666; line-height: 1.6; }

.copyright { text-align: center; padding: 40rpx 0; font-size: 22rpx; color: #CCC; }
