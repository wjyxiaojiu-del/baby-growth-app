.page-container { padding-bottom: 60rpx; }

.section-title-bar {
  font-size: 26rpx;
  color: #999;
  padding: 32rpx 32rpx 16rpx;
}

.settings-list { padding: 0; }

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(248, 240, 241, 0.5);
}

.setting-item:last-child { border-bottom: none; }
.setting-text { flex: 1; margin-right: 20rpx; }
.setting-label { display: block; font-size: 28rpx; color: #333; font-weight: 600; }
.setting-desc { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }

.danger-card { padding: 0; }

.danger-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.danger-item:active { background: rgba(255, 245, 245, 0.5); }
.danger-text { flex: 1; }
.danger-label { display: block; font-size: 28rpx; color: #FF4444; font-weight: 600; }
.danger-desc { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.danger-arrow { font-size: 36rpx; color: #CCC; }

.privacy-note {
  margin: 32rpx;
  padding: 24rpx;
  background: rgba(248, 248, 248, 0.5);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.note-title { display: block; font-size: 26rpx; font-weight: 600; color: #666; margin-bottom: 12rpx; }
.note-text { display: block; font-size: 24rpx; color: #999; line-height: 1.8; }
