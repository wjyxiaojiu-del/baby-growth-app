.page-container { padding-bottom: 0; height: 100vh; display: flex; flex-direction: column; }

.loading-wrap { display: flex; align-items: center; justify-content: center; height: 60vh; }

.tab-bar {
  display: flex; background: #FFF; padding: 16rpx 24rpx; gap: 16rpx;
  border-bottom: 1rpx solid rgba(255,181,194,0.2); flex-shrink: 0;
}
.tab-item {
  flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx;
  color: #888; border-radius: 24rpx;
}
.tab-item.active {
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: #FFF; font-weight: 600;
}

.content-area { flex: 1; overflow-y: auto; padding: 0 24rpx; }

.month-badge {
  margin: 24rpx 0 16rpx; padding: 20rpx 32rpx; text-align: center;
  background: linear-gradient(135deg, rgba(255,107,129,0.08), rgba(255,181,194,0.12));
  border-radius: 24rpx;
}
.badge-text { font-size: 28rpx; color: #FF6B81; font-weight: 600; }

.article-list { display: flex; flex-direction: column; gap: 16rpx; padding-bottom: 24rpx; }
.article-card { display: flex; align-items: center; gap: 20rpx; padding: 24rpx; }
.article-icon { font-size: 44rpx; flex-shrink: 0; }
.article-info { flex: 1; min-width: 0; }
.article-title { display: block; font-size: 28rpx; font-weight: 600; color: #333; }
.article-category { display: block; font-size: 22rpx; color: #FF6B81; margin-top: 4rpx; }
.article-summary { display: block; font-size: 24rpx; color: #888; margin-top: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.article-arrow { font-size: 36rpx; color: #CCC; flex-shrink: 0; }
.unfav-btn { font-size: 28rpx; color: #CCC; padding: 12rpx; }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 48rpx; text-align: center;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 34rpx; font-weight: 700; color: #333; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #888; }

/* AI问答 */
.chat-area { display: flex; flex-direction: column; padding: 0; }

.chat-empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 48rpx; text-align: center;
}
.chat-empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.chat-empty-title { font-size: 36rpx; font-weight: 700; color: #333; margin-bottom: 12rpx; }
.chat-empty-desc { font-size: 26rpx; color: #888; margin-bottom: 32rpx; }

.quick-questions { display: flex; flex-wrap: wrap; gap: 16rpx; justify-content: center; }
.quick-q {
  padding: 12rpx 28rpx; border-radius: 32rpx;
  background: rgba(255,107,129,0.1); color: #FF6B81;
  font-size: 24rpx;
}

.chat-messages { flex: 1; padding: 24rpx; height: 0; }

.chat-msg { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.chat-msg.user { flex-direction: row-reverse; }

.msg-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; font-size: 28rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: #F5F5F5; }

.msg-bubble {
  max-width: 70%; padding: 20rpx 24rpx; border-radius: 24rpx;
  font-size: 28rpx; line-height: 1.6;
}
.chat-msg.user .msg-bubble { background: linear-gradient(135deg, #FF6B81, #FF8E9E); color: #FFF; border-bottom-right-radius: 8rpx; }
.chat-msg.ai .msg-bubble { background: #F5F5F5; color: #333; border-bottom-left-radius: 8rpx; }

.loading-dots::after { content: '...'; animation: dots 1.5s steps(3) infinite; }
@keyframes dots { 0% { content: '.'; } 33% { content: '..'; } 66% { content: '...'; } }

.chat-input-bar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx; background: #FFF;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  flex-shrink: 0;
}
.chat-input {
  flex: 1; height: 72rpx; padding: 0 24rpx;
  background: #F5F5F5; border-radius: 36rpx;
  font-size: 28rpx;
}
.chat-send {
  padding: 16rpx 32rpx; border-radius: 36rpx;
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: #FFF; font-size: 28rpx; font-weight: 600;
}
