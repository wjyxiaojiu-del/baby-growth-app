.page-container { padding-bottom: 120rpx; }

/* 月龄选择器 — 毛玻璃 */
.month-selector {
  background: rgba(255, 255, 255, 0.6);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
}

.month-scroll { white-space: nowrap; padding: 0 24rpx; }

.month-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.5);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  transition: all 0.2s;
}

.month-chip.active {
  background: rgba(255, 107, 129, 0.85);
  color: #FFF;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.3);
}

.age-hint { margin-top: 0; padding: 20rpx 32rpx; }
.age-hint-text { font-size: 24rpx; color: #888; }

/* 领域区块 */
.domain-section {
  margin: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.06);
}

.domain-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: rgba(255, 248, 249, 0.5);
  border-bottom: 1rpx solid rgba(245, 230, 232, 0.4);
}

.domain-icon { font-size: 36rpx; margin-right: 16rpx; }
.domain-name { font-size: 30rpx; font-weight: 600; color: #333; flex: 1; }
.domain-count { font-size: 24rpx; color: #999; }

.milestone-list { padding: 8rpx 0; }

.milestone-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(248, 240, 241, 0.5);
  transition: background 0.2s;
}

.milestone-item:last-child { border-bottom: none; }
.milestone-item:active { background: rgba(255, 245, 245, 0.5); }
.milestone-item.checked { background: rgba(240, 255, 240, 0.4); }

.check-box {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid rgba(221, 221, 221, 0.6);
  border-radius: 12rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.2s;
}

.milestone-item.checked .check-box {
  background: rgba(76, 175, 80, 0.85);
  border-color: transparent;
  color: #FFF;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.milestone-text { font-size: 28rpx; color: #333; flex: 1; }
.milestone-item.checked .milestone-text { color: #4CAF50; }

.action-bar { padding: 32rpx 24rpx; }

/* 评估结果 */
.result-section { padding: 0 24rpx 40rpx; }

.result-card {
  background: rgba(255, 240, 242, 0.6);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 213, 219, 0.4);
}

.result-title { font-size: 34rpx; font-weight: 700; color: #333; text-align: center; margin-bottom: 32rpx; }

.total-score { display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx; }

.score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.7);
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.score-number { font-size: 56rpx; font-weight: 700; color: #FF6B81; line-height: 1; }
.score-unit { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.score-desc { font-size: 28rpx; color: #666; margin-top: 16rpx; }

.domain-scores {
  background: rgba(255, 255, 255, 0.5);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.domain-score-item { display: flex; align-items: center; margin-bottom: 20rpx; }
.domain-score-item:last-child { margin-bottom: 0; }
.score-label { width: 120rpx; flex-shrink: 0; }
.score-domain-name { display: block; font-size: 26rpx; color: #333; font-weight: 600; }
.score-detail { display: block; font-size: 20rpx; color: #999; }

.score-bar-bg {
  flex: 1;
  height: 20rpx;
  background: rgba(245, 230, 232, 0.5);
  border-radius: 10rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.score-bar { height: 100%; border-radius: 10rpx; transition: width 0.5s ease; }
.score-value { width: 80rpx; text-align: right; font-size: 26rpx; font-weight: 600; color: #333; }

.insight-section { margin-bottom: 20rpx; }
.insight-title { font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.insight-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }

.insight-tag {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
}

.insight-tag.strong { background: rgba(232, 245, 233, 0.7); color: #2E7D32; }
.insight-tag.weak { background: rgba(255, 243, 224, 0.7); color: #E65100; }

.ai-report-link {
  text-align: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(245, 230, 232, 0.5);
}

.ai-report-link text { font-size: 28rpx; color: #FF6B81; font-weight: 600; }
