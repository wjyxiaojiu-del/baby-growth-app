.page-container { padding-bottom: 40rpx; }

.header {
  text-align: center;
  padding: 32rpx;
}

.header-title { display: block; font-size: 34rpx; font-weight: 700; color: #333; }
.header-desc { display: block; font-size: 24rpx; color: #999; margin-top: 8rpx; }

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 213, 219, 0.5);
  border-top-color: #FF6B81;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.vaccine-list { padding: 0 24rpx; }

.vaccine-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 0;
  padding: 24rpx;
}

.vaccine-left { display: flex; align-items: center; flex: 1; }

.vaccine-status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.vaccine-info { flex: 1; }
.vaccine-name { display: block; font-size: 28rpx; font-weight: 600; color: #333; }

.vaccine-meta { display: flex; gap: 16rpx; margin-top: 8rpx; }

.vaccine-category {
  font-size: 22rpx;
  color: #FF6B81;
  background: rgba(255, 228, 232, 0.6);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.vaccine-date { font-size: 22rpx; color: #999; }

.vaccine-right { flex-shrink: 0; margin-left: 16rpx; }
.vaccine-done { font-size: 24rpx; color: #4CAF50; font-weight: 600; }

.vaccine-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 600;
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
}

.vaccine-btn.overdue {
  background: rgba(255, 228, 232, 0.7);
  color: #FF6B81;
}

.vaccine-btn.upcoming {
  background: rgba(255, 243, 224, 0.7);
  color: #FF9800;
}

.vaccine-pending { font-size: 22rpx; color: #CCC; }

/* 图例 */
.legend {
  display: flex;
  justify-content: space-around;
  margin: 32rpx 24rpx;
  padding: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #888;
}

.legend-dot { width: 12rpx; height: 12rpx; border-radius: 50%; }
